                { "color": "#299c46", "state": 0, "value": 0 },
                { "color": "#ed8128", "state": 1, "value": 70 },
                { "color": "#f53636", "state": 2, "value": 90 }
              ],
              "colors": ["#299c46", "#ed8128", "#f53636"],
              "unitFormat": "percent", "decimals": 0, "scaledDecimals": 0, "enabled": true,
              "operatorName": "last", "prefix": "", "suffix": "",
              "clickThrough": "", "clickThroughSanitize": true, "clickThroughOpenNewTab": true,
              "clickThroughCustomTargetEnabled": false, "clickThroughCustomTarget": "",
              "showTimestampEnabled": false, "showTimestampFormat": "", "showTimestampYOffset": 0, "order": 1
            },
            {
              "label": "Pods", "metricName": "/^Pods/", "alias": "",
              "thresholds": [{ "color": "#299c46", "state": 0, "value": 0 }],
              "colors": ["#299c46"],
              "unitFormat": "short", "decimals": 0, "scaledDecimals": 0, "enabled": true,
              "operatorName": "last", "prefix": "", "suffix": "",
              "clickThrough": "", "clickThroughSanitize": true, "clickThroughOpenNewTab": true,
              "clickThroughCustomTargetEnabled": false, "clickThroughCustomTarget": "",
              "showTimestampEnabled": false, "showTimestampFormat": "", "showTimestampYOffset": 0, "order": 2
            }
          ]
        },
        "compositeGlobalAliasingEnabled": false,
        "compositeConfig": { "animationSpeed": "2000", "composites": [], "enabled": false },
        "tooltipPrimarySortDirection": 0, "tooltipPrimarySortByField": "name",
        "tooltipSecondarySortDirection": 0, "tooltipSecondarySortByField": "value",
        "tooltipDisplayMode": "all", "tooltipDisplayTextTriggeredEmpty": "OK"
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
