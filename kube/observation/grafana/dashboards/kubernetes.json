                { "color": "#f53636", "state": 2, "value": 90 }
              ],
              "colors": ["#299c46", "#ed8128", "#f53636"],
              "unitFormat": "percent", "decimals": 0, "scaledDecimals": 0, "enabled": true,
              "operatorName": "last", "prefix": "", "suffix": "",
              "clickThrough": "", "clickThroughSanitize": true, "clickThroughOpenNewTab": true,
              "clickThroughCustomTargetEnabled": false, "clickThroughCustomTarget": "",
              "showTimestampEnabled": false, "showTimestampFormat": "", "showTimestampYOffset": 0, "order": 0
