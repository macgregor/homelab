    {
      "id": 102,
      "title": "Cluster",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "count(kube_node_info)", "legendFormat": "Nodes", "instant": true },
        { "refId": "B", "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})", "legendFormat": "Ready", "instant": true },
        { "refId": "C", "expr": "sum(kube_pod_status_phase{phase=\"Running\"})", "legendFormat": "Running Pods", "instant": true },
        { "refId": "D", "expr": "count(kube_deployment_spec_replicas)", "legendFormat": "Deployments", "instant": true }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none", "colorMode": "background", "textMode": "value_and_name",
        "justifyMode": "center", "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      }
    },

    {
      "title": "Resource Usage",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }
    },
    {
      "id": 130,
      "title": "Memory by Container",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc(\n  sum by (workload, namespace) (\n    label_replace(\n      label_replace(\n        label_replace(\n          label_replace(\n            kubernetes_pod_container_memory_working_set_bytes{namespace=~\"$namespace\"},\n            \"workload\", \"$1\", \"pod_name\", \"(.+)\"\n          ),\n          \"workload\", \"$1\", \"pod_name\", \"(.+)-[0-9]+$\"\n        ),\n        \"workload\", \"$1\", \"pod_name\", \"(.+)-[a-z0-9]{5}$\"\n      ),\n      \"workload\", \"$1\", \"pod_name\", \"(.+)-[0-9a-f]{6,10}-[a-z0-9]{5}$\"\n    )\n  )\n)",
          "legendFormat": "{{ namespace }}/{{ workload }}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut",
        "displayLabels": []
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "id": 131,
      "title": "CPU by Container",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc(\n  sum by (workload, namespace) (\n    label_replace(\n      label_replace(\n        label_replace(\n          label_replace(\n            kubernetes_pod_container_cpu_usage_nanocores{namespace=~\"$namespace\"},\n            \"workload\", \"$1\", \"pod_name\", \"(.+)\"\n          ),\n          \"workload\", \"$1\", \"pod_name\", \"(.+)-[0-9]+$\"\n        ),\n        \"workload\", \"$1\", \"pod_name\", \"(.+)-[a-z0-9]{5}$\"\n      ),\n      \"workload\", \"$1\", \"pod_name\", \"(.+)-[0-9a-f]{6,10}-[a-z0-9]{5}$\"\n    )\n  ) / 1e6\n)",
          "legendFormat": "{{ namespace }}/{{ workload }}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut",
        "displayLabels": []
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mmcpu",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },

    {
      "title": "Workload Health",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },
    {
      "id": 132,
      "title": "Container Restarts",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 21 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(\n  max_over_time(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[$__range])\n  - min_over_time(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[$__range])\n) or vector(0)",
          "legendFormat": "Restarts",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none", "colorMode": "background", "textMode": "value_and_name",
        "justifyMode": "center", "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 140,
      "title": "Failed Jobs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 21 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_job_status_failed{namespace=~\"$namespace\"}) or vector(0)",
          "legendFormat": "Failed Jobs",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none", "colorMode": "background", "textMode": "value_and_name",
        "justifyMode": "center", "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 143,
      "title": "Unavailable Deployments",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 21 },
      "targets": [
        {
          "refId": "A",
          "expr": "count(\n  kube_deployment_spec_replicas{namespace=~\"$namespace\"} > 0\n  unless\n  kube_deployment_status_replicas_available{namespace=~\"$namespace\"} > 0\n) or vector(0)",
          "legendFormat": "Unavailable",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "graphMode": "none", "colorMode": "background", "textMode": "value_and_name",
        "justifyMode": "center", "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 133,
      "title": "Pod Phases",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (phase) (kube_pod_status_phase{namespace=~\"$namespace\"})",
          "legendFormat": "{{ phase }}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "legend": { "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "multi" },
        "pieType": "donut"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Running" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Succeeded" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "Pending" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Unknown" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      }
    },
    {
      "id": 141,
      "title": "Restarting Containers",
      "description": "Containers that restarted during the selected time range",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "expr": "sort_desc(\n  sum by (container, namespace, pod) (\n    max_over_time(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[$__range])\n    - min_over_time(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[$__range])\n  ) > 0\n)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Restarts", "desc": true }]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "__name__": true, "job": true, "instance": true, "uid": true
            },
            "renameByName": {
              "namespace": "Namespace", "pod": "Pod", "container": "Container", "Value": "Restarts"
            },
            "indexByName": { "namespace": 0, "pod": 1, "container": 2, "Value": 3 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "noValue": "No restarts" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Restarts" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }, { "color": "red", "value": 5 }] } },
              { "id": "custom.displayMode", "value": "color-background-solid" }
            ]
          }
        ]
      }
    },

    {
      "title": "Resource Trends",
      "type": "row",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "panels": [
    {
      "id": 170,
      "title": "Memory by Namespace",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 30 },
      "targets": [
