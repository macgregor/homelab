{
  "__inputs": [
    {
      "name": "DS_VICTORIAMETRICS",
      "label": "VictoriaMetrics",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" }
  ],
  "id": null,
  "uid": "kubernetes",
  "title": "Kubernetes",
  "description": "Cluster workloads, pod health, resource usage, and deployment status",
  "tags": ["homelab", "kubernetes"],
  "timezone": "browser",
  "editable": false,
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "VictoriaMetrics", "value": "VictoriaMetrics" },
        "hide": 0,
        "label": "Datasource"
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "query": "label_values(kube_pod_info, namespace)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "hide": 0,
        "label": "Namespace"
      }
    ]
  },
  "panels": [
    {
      "title": "Nodes",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 100,
      "title": "k3-m1",
      "type": "grafana-polystat-panel",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "targets": [
        { "refId": "A", "expr": "100 - cpu_usage_idle{cpu=\"cpu-total\", host=\"k3-m1\"}", "legendFormat": "CPU", "instant": true },
        { "refId": "B", "expr": "mem_used_percent{host=\"k3-m1\"}", "legendFormat": "Memory", "instant": true },
        { "refId": "C", "expr": "sum(kube_pod_info{node=\"k3-m1\"})", "legendFormat": "Pods", "instant": true }
      ],
      "options": {
        "autoSizeColumns": true, "autoSizeRows": true, "autoSizePolygons": true,
        "ellipseCharacters": 18, "ellipseEnabled": true,
        "globalAutoScaleFonts": true,
        "globalClickthrough": "", "globalClickthroughNewTabEnabled": true, "globalClickthroughSanitizedEnabled": true,
        "globalClickthroughCustomTargetEnabled": false, "globalClickthroughCustomTarget": "",
        "globalDecimals": 0, "globalDisplayMode": "all", "globalDisplayTextTriggeredEmpty": "OK",
        "globalFillColor": "#0a55a1", "globalGradientsEnabled": true,
        "globalLabelFontSize": 11, "globalValueFontSize": 18, "globalCompositeValueFontSize": 18,
        "globalOperator": "last",
        "globalPolygonBorderSize": 2, "globalPolygonBorderColor": "rgba(0,0,0,0.2)", "globalPolygonSize": "",
        "globalRegexPattern": "", "globalShape": "hexagon_pointed_top",
        "globalShowValueEnabled": true,
        "globalShowTimestampEnabled": false, "globalShowTimestampFormat": "", "globalShowTimestampFontSize": 12,
        "globalShowTimestampPosition": "below_value", "globalShowTimestampYOffset": 0,
        "globalShowTooltipColumnHeadersEnabled": true,
        "globalTextFontAutoColor": "#FFFFFF", "globalTextFontAutoColorEnabled": true, "globalTextFontColor": "#FFFFFF",
        "globalTextFontFamily": "Inter",
        "globalThresholdsConfig": [
          { "color": "#299c46", "state": 0, "value": 0 },
          { "color": "#ed8128", "state": 1, "value": 70 },
          { "color": "#f53636", "state": 2, "value": 90 }
        ],
        "globalTooltipsEnabled": true, "globalTooltipsShowTimestampEnabled": true, "globalTooltipsShowValueEnabled": true,
        "globalTooltipsFontFamily": "Inter", "globalUnitFormat": "percent",
        "layoutDisplayLimit": 100, "layoutNumColumns": 2, "layoutNumRows": 0,
        "panelHeight": 0, "panelWidth": 0, "panelId": 0, "radius": null,
        "sortByField": "name", "sortByDirection": 1,
        "overrideConfig": {
          "overrides": [
