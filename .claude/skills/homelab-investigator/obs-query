def cmd_network(args):
    """Network traffic and error stats."""
    node = args[0] if args else None
    data = {}

    for r in vm_query(f"rate({_q('net_bytes_recv', interface='eth0', host=node)}[5m])"):
        host = label(r, "host")
        data.setdefault(host, {"host": host})["recv_kbs"] = round(val(r) / 1024, 1)

    for r in vm_query(f"rate({_q('net_bytes_sent', interface='eth0', host=node)}[5m])"):
        host = label(r, "host")
        data.setdefault(host, {"host": host})["sent_kbs"] = round(val(r) / 1024, 1)

    for metric in ["net_err_in", "net_err_out", "net_drop_in", "net_drop_out"]:
        for r in vm_query(_q(metric, interface="eth0", host=node)):
            host = label(r, "host")
            data.setdefault(host, {"host": host})[metric] = int(val(r))

    for host in sorted(data):
        emit(data[host])


# --- Infrastructure ---

def cmd_router(args):
    """MikroTik router health."""
    result = {}

    v = vm_scalar("snmp_mikrotik_cpu_load")
    if v is not None:
        result["cpu_load"] = round(v, 1)

    v = vm_scalar("snmp_mikrotik_cpu_temperature")
    if v is not None:
        result["temp_c"] = round(v, 1)

    used = vm_scalar("snmp_mikrotik_memory_used")
    total = vm_scalar("snmp_mikrotik_memory_total")
    if used is not None and total and total > 0:
        result["mem_pct"] = round(100 * used / total, 1)
        result["mem_used"] = int(used)
        result["mem_total"] = int(total)

    v = vm_scalar("snmp_mikrotik_uptime")
    if v is not None:
        result["uptime_s"] = int(v)

    # Interfaces
    interfaces = []
    oper = {}
    for r in vm_query("snmp_mikrotik_interface_oper_status"):
        oper[label(r, "name")] = int(val(r))

    recv = {}
    for r in vm_query("rate(snmp_mikrotik_interface_bytes_recv[5m])"):
        recv[label(r, "name")] = round(val(r) / 1024, 1)

    sent = {}
    for r in vm_query("rate(snmp_mikrotik_interface_bytes_sent[5m])"):
        sent[label(r, "name")] = round(val(r) / 1024, 1)

    for name in sorted(oper):
        interfaces.append({
            "name": name,
            "oper_status": oper[name],
            "recv_kbs": recv.get(name, 0),
            "sent_kbs": sent.get(name, 0),
        })
    result["interfaces"] = interfaces

    emit(result)


def cmd_nas(args):
    """Synology NAS health."""
    result = {}

    v = vm_scalar("snmp_synology_system_temperature")
    if v is not None:
        result["temp_c"] = round(v, 1)

    for field in ["load_1m", "load_5m", "load_15m"]:
        v = vm_scalar(f"snmp_synology_{field}")
        if v is not None:
            result[field] = round(v, 2)

    v = vm_scalar("snmp_synology_uptime")
    if v is not None:
        result["uptime_s"] = int(v)

    # Memory: compute used from components
    mem_total = vm_scalar("snmp_synology_memory_total_real_kb")
    mem_avail = vm_scalar("snmp_synology_memory_avail_real_kb")
    mem_buf = vm_scalar("snmp_synology_memory_buffered_kb")
    mem_cached = vm_scalar("snmp_synology_memory_cached_kb")
    if all(v is not None for v in [mem_total, mem_avail, mem_buf, mem_cached]) and mem_total > 0:
        mem_used = mem_total - mem_avail - mem_buf - mem_cached
        result["mem_used_kb"] = int(mem_used)
        result["mem_total_kb"] = int(mem_total)
        result["mem_pct"] = round(100 * mem_used / mem_total, 1)

    # Disks
    disks = []
    for r in vm_query("snmp_synology_disk_disk_status"):
        disk = {"disk_id": label(r, "disk_id"), "status": int(val(r))}
        disks.append(disk)
    for r in vm_query("snmp_synology_disk_disk_temperature"):
        did = label(r, "disk_id")
        for d in disks:
            if d["disk_id"] == did:
                d["temp_c"] = round(val(r), 1)
    result["disks"] = disks

    # RAID
    raids = []
    for r in vm_query("snmp_synology_raid_raid_status"):
        raids.append({"raid_name": label(r, "raid_name"), "status": int(val(r))})
    result["raids"] = raids

    emit(result)


def cmd_nas_storage(args):
    """Synology NAS storage volumes."""
    vol_filter = 'storage_descr=~"/volume[0-9]+"'

    used = {}
    for r in vm_query(f"snmp_synology_storage_storage_used{{{vol_filter}}}"):
        used[label(r, "storage_descr")] = val(r)

    size = {}
    for r in vm_query(f"snmp_synology_storage_storage_size{{{vol_filter}}}"):
        size[label(r, "storage_descr")] = val(r)

    alloc = {}
    for r in vm_query(f"snmp_synology_storage_allocation_units{{{vol_filter}}}"):
        alloc[label(r, "storage_descr")] = val(r)

    for vol in sorted(used):
        if vol in size and vol in alloc:
            a = alloc[vol]
            used_bytes = used[vol] * a
            size_bytes = size[vol] * a
            pct = (used_bytes / size_bytes * 100) if size_bytes > 0 else 0
            emit({
                "volume": vol,
                "used_gb": round(used_bytes / 1024**3, 1),
                "size_gb": round(size_bytes / 1024**3, 1),
                "used_pct": round(pct, 1),
            })


# --- Kubernetes ---

def cmd_pod_restarts(args):
    """Pod restart counts over a window."""
    ns = args[0] if args else None
    window = args[1] if len(args) > 1 else "1h"
    ns_sel = f'namespace="{ns}",' if ns else ""

    for r in vm_query(f"sort_desc(increase(kube_pod_container_status_restarts_total{{{ns_sel}}}[{window}]) > 0)"):
        emit({
            "pod": label(r, "pod"),
            "namespace": label(r, "namespace"),
            "container": label(r, "container"),
            "restarts": round(val(r), 1),
        })


def cmd_resource_pressure(args):
    """Memory usage vs limits per pod."""
    ns = args[0] if args else None
    ns_sel = f'namespace="{ns}",' if ns else ""

    # Telegraf kubernetes input: pod_name/container_name labels
    usage = {}
    for r in vm_query(f"kubernetes_pod_container_memory_working_set_bytes{{{ns_sel}}}"):
        key = (label(r, "pod_name"), label(r, "container_name"), label(r, "namespace"))
        usage[key] = val(r)

    # KSM: pod/container labels
    limits = {}
    for r in vm_query(f'kube_pod_container_resource_limits{{{ns_sel}resource="memory"}}'):
        key = (label(r, "pod"), label(r, "container"), label(r, "namespace"))
        limits[key] = val(r)

    # Join by matching pod names
    for (pod, container, ns_name), used in sorted(usage.items()):
        limit = limits.get((pod, container, ns_name))
        out = {
            "pod": pod,
            "container": container,
            "namespace": ns_name,
            "usage_mb": round(used / 1024 / 1024, 1),
        }
        if limit:
            out["limit_mb"] = round(limit / 1024 / 1024, 1)
            out["ratio"] = round(used / limit, 3)
        emit(out)


def cmd_deployments(args):
    """Deployment and DaemonSet health."""
    ns = args[0] if args else None
    ns_sel = f'namespace="{ns}",' if ns else ""

    # Deployments
    desired = {}
    for r in vm_query(f"kube_deployment_spec_replicas{{{ns_sel}}}"):
        key = (label(r, "namespace"), label(r, "deployment"))
        desired[key] = int(val(r))

    available = {}
    for r in vm_query(f"kube_deployment_status_replicas_available{{{ns_sel}}}"):
        key = (label(r, "namespace"), label(r, "deployment"))
        available[key] = int(val(r))

    for key in sorted(desired):
        ns_name, deploy = key
        d = desired[key]
        a = available.get(key, 0)
        emit({
            "type": "deployment", "namespace": ns_name, "name": deploy,
            "desired": d, "available": a, "unavailable": d - a,
            "healthy": d - a == 0,
        })

    # DaemonSets
    ds_desired = {}
    for r in vm_query(f"kube_daemonset_status_desired_number_scheduled{{{ns_sel}}}"):
        key = (label(r, "namespace"), label(r, "daemonset"))
        ds_desired[key] = int(val(r))

    ds_ready = {}
    for r in vm_query(f"kube_daemonset_status_number_ready{{{ns_sel}}}"):
        key = (label(r, "namespace"), label(r, "daemonset"))
        ds_ready[key] = int(val(r))

    for key in sorted(ds_desired):
        ns_name, ds = key
        d = ds_desired[key]
        r = ds_ready.get(key, 0)
        emit({
            "type": "daemonset", "namespace": ns_name, "name": ds,
            "desired": d, "ready": r, "unavailable": d - r,
            "healthy": d - r == 0,
        })


def cmd_node_conditions(args):
    """Kubernetes node conditions."""
    for r in vm_query('kube_node_status_condition{status="true"} == 1'):
        condition = label(r, "condition")
        emit({
            "node": label(r, "node"),
            "condition": condition,
            "ok": condition == "Ready",
        })


# --- Logs ---

def cmd_ingress_status(args):
    """Ingress request counts by HTTP status code."""
    window = args[0] if args else "1h"
    query = (
        'log_type:access stream:stdout '
        '| extract "\\" <status> <_>" from _msg '
        '| filter status:~"^[0-9]+$" '
        '| stats by (status) count() as requests'
    )
    for r in vl_stats(query, time=window):
        emit(r)


def cmd_ingress_errors(args):
    """Ingress 4xx/5xx error log entries."""
    window = args[0] if args else "1h"
    limit = int(args[1]) if len(args) > 1 else 50
    query = (
        f'_time:{window} log_type:access stream:stdout '
        '| extract "<client_ip> <_> <_> [<_>] '
        '\\"<method> <path> <_>\\" <status> <body_bytes> '
        '\\"<_>\\" \\"<_>\\" <_> <request_time> [<upstream>]" from _msg '
        '| filter status:~"^[45]" '
        '| fields _time, client_ip, method, path, status, body_bytes, request_time, upstream'
    )
    fields = ["_time", "client_ip", "method", "path", "status", "body_bytes", "request_time", "upstream"]
    for e in vl_query(query, limit=limit):
        emit({k: e.get(k) for k in fields})


def cmd_firewall_drops(args):
    """MikroTik firewall drop events."""
    window = args[0] if args else "1h"
    limit = int(args[1]) if len(args) > 1 else 50
    query = (
        f'_time:{window} _msg:~"firewall,info" '
        '| extract "firewall,info <action> <chain>: in:<in_iface> out:<out_iface>, '
        'connection-state:<conn_state> src-mac <src_mac>, proto <proto>, '
        '<src_ip>:<src_port>-><dst_ip>:<dst_port>, len <pkt_len>" from _msg '
        '| fields _time, action, chain, proto, conn_state, src_ip, src_port, dst_ip, dst_port'
    )
    fields = ["_time", "action", "chain", "proto", "src_ip", "src_port", "dst_ip", "dst_port"]
    for e in vl_query(query, limit=limit):
        emit({k: e.get(k) for k in fields})


def cmd_modsecurity(args):
    """ModSecurity events from ingress."""
    window = args[0] if args else "1h"
    limit = int(args[1]) if len(args) > 1 else 50
    for e in vl_query(f"_time:{window} log_type:modsecurity", limit=limit):
        emit({"_time": e.get("_time"), "_msg": e.get("_msg")})


def cmd_search_logs(args):
    """Search logs with raw LogsQL query."""
    query = require_arg(args, "query")
    limit = int(args[1]) if len(args) > 1 else 50
    for e in vl_query(query, limit=limit):
        emit(e)


