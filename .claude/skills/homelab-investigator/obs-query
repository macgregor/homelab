def cmd_help(_args):
    print("Usage: obs-query <command> [args...]")
    print()
    max_name = max(len(n) for n in COMMANDS)
    max_usage = max(len(u) for _, u, _ in COMMANDS.values())
    for name in sorted(COMMANDS):
        _, usage, desc = COMMANDS[name]
        print(f"  {name:<{max_name}}  {usage:<{max_usage}}  {desc}")


if __name__ == "__main__":
    cmd = sys.argv[1] if len(sys.argv) > 1 else "help"
    if cmd in ("help", "--help", "-h"):
        cmd_help([])
        sys.exit(0)
    if cmd not in COMMANDS:
        emit_error(f"Unknown command: {cmd}")
        cmd_help([])
        sys.exit(1)
    COMMANDS[cmd][0](sys.argv[2:])
